# QuestBoard Stellar MCP environment variables
# Copy to .env and fill in. Never commit .env.

# Network: testnet | mainnet
STELLAR_NETWORK=testnet

# Contract IDs (deployed via stellar contract deploy)
STELLAR_BOUNTY_FACTORY_ID=
STELLAR_AGENT_REGISTRY_ID=

# RPC endpoints (optional — defaults to SDF public endpoints)
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Signing policy: safe | guarded | expert
# safe = unsigned XDR only (recommended)
STELLAR_AUTO_SIGN_POLICY=safe

# Optional: testnet signing key (NEVER for mainnet)
# STELLAR_SECRET_KEY=

# Optional: custom allowed hosts
# STELLAR_ALLOWED_HOSTS=

# Optional: SEP anchor domains
# STELLAR_TRUSTED_ANCHOR_DOMAINS=

# PerkOS x402 relayer (for multi-hop agent payments)
PERKOS_RELAYER_URL=https://stellar-relayer.perkos.xyz
PERKOS_STACK_URL=https://stack.perkos.xyz