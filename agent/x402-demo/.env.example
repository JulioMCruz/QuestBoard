# QuestBoard x402 demo — copy to .env.local (gitignored) and fill in.

X402_NETWORK=stellar:testnet
# Full base path to the relayer's x402 facilitator plugin (client appends /verify,/settle,/supported)
FACILITATOR_URL=https://stellar-relayer.perkos.xyz/api/v1/plugins/x402-facilitator/call

# Relayer Bearer token — SERVER-SIDE ONLY, used by the agents server to call the
# facilitator's verify/settle. Obtain from the relayer operator. Never commit.
RELAYER_API_KEY=<RELAYER_API_KEY>

# Agents B & C (payees). Each must hold a USDC trustline to receive payment.
AGENT_B_ADDRESS=GAYHX54UTMNW6DYSMW3KWRFN2YDHNDSZGJ6FOLBZ6565FUXSEIDTWVYW
AGENT_C_ADDRESS=GBNM4MNPVDV7EGUVUEKY4EHYDBYD572TUTRI3FUBP5AITTBVBVCMCQUR
AGENTS_PORT=4021
AGENTS_URL=http://localhost:4021

# Agent A (payer) — Stellar SECRET seed (S...). NEVER commit.
# Must hold a USDC trustline + USDC balance (fund via the Circle testnet faucet).
AGENT_A_SECRET=<S...>

# Optional: close the bounty loop. If BOUNTY_ID is set, after paying B & C the
# orchestrator claims the bounty (if Open) and submits proof to the BountyFactory.
SOROBAN_RPC=https://soroban-testnet.stellar.org
BOUNTY_FACTORY_ID=CDFHTM4NKHFQFXY6VO4HPHWNOY56XIB3BI5HCHGTJ2GUJML3CLA2VPZ6
# BOUNTY_ID=

# Reputation loop (register + indexer):
AGENT_REGISTRY_ID=CCHFKVBTJHZEQVKA7H3MLY36SPRJHRH2IDLUWS3XY2DKIF5N5Y3TRBID
# Registry admin SECRET — required by the indexer to call record_payment. NEVER commit.
ADMIN_SECRET=<S...>

# Automated acceptance (npm run accept): the poster's SECRET. The bot inspects each
# submitted bounty's proof and releases escrow only if it passes the check. NEVER commit.
POSTER_SECRET=<S...>
